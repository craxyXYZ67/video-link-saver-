<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================
         LIGHT THEME — Bright, modern, Gen-Z palette
         ================================================================ -->

    <!-- Core colors -->
    <Color x:Key="BackgroundColor">#F8F5FF</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#6C63FF</Color>
    <Color x:Key="AccentHoverColor">#574FD6</Color>
    <Color x:Key="AccentLightColor">#EDE9FF</Color>
    <Color x:Key="TextPrimaryColor">#1A1A2E</Color>
    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="CardBorderColor">#E0D9FF</Color>
    <Color x:Key="ButtonSecondaryBg">#F3F0FF</Color>
    <Color x:Key="InputBorderColor">#D1D5DB</Color>
    <Color x:Key="InputFocusColor">#6C63FF</Color>
    <Color x:Key="TagYellow">#FEF3C7</Color>
    <Color x:Key="TagYellowText">#92400E</Color>
    <Color x:Key="TagPurple">#EDE9FF</Color>
    <Color x:Key="TagPurpleText">#4C1D95</Color>
    <Color x:Key="TagGreen">#D1FAE5</Color>
    <Color x:Key="TagGreenText">#065F46</Color>
    <Color x:Key="TagBlue">#DBEAFE</Color>
    <Color x:Key="TagBlueText">#1E3A8A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="ButtonSecondaryBgBrush" Color="{StaticResource ButtonSecondaryBg}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="InputFocusBrush" Color="{StaticResource InputFocusColor}"/>

    <!-- Gradient for main background -->
    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8F5FF" Offset="0"/>
        <GradientStop Color="#EDE9FF" Offset="0.5"/>
        <GradientStop Color="#F0F4FF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Gradient for primary buttons -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6C63FF" Offset="0"/>
        <GradientStop Color="#A78BFA" Offset="1"/>
    </LinearGradientBrush>

    <!-- Theme toggle icon text -->
    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="ThemeToggleIcon">☀️</System:String>

</ResourceDictionary>
