<UserControl x:Class="VideoLinkSaver.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource BackgroundGradientBrush}">
        <!-- Centered content card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="56,48">
            <Border.Effect>
                <DropShadowEffect Color="#6C63FF" BlurRadius="40" ShadowDepth="0" Opacity="0.12"/>
            </Border.Effect>

            <StackPanel Width="340">
                <!-- Decorative icon -->
                <Border Background="{DynamicResource AccentGradientBrush}"
                        CornerRadius="20"
                        Width="72" Height="72"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#6C63FF" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <TextBlock Text="🎬" FontSize="34"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Headline -->
                <TextBlock Text="Video Link Saver"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Your personal offline video library"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- 1. Create the Link -->
                <Button Content="➕  Create the Link"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding GoToCreateLinkCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,14"/>

                <!-- 2. Search -->
                <Button Content="🔍  Search"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding GoToSearchCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,14"/>

                <!-- 3. Data storage info -->
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding GoToDataLocationCommand}"
                        HorizontalAlignment="Stretch">
                    <TextBlock Text="📂  Where is my data stored?"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
