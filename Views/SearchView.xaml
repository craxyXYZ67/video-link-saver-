<UserControl x:Class="VideoLinkSaver.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VideoLinkSaver.ViewModels"
             xmlns:models="clr-namespace:VideoLinkSaver.Models">

    <Grid Background="{DynamicResource BackgroundGradientBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- filters card -->
            <RowDefinition Height="*"/>       <!-- results -->
        </Grid.RowDefinitions>

        <!-- ================================================================
             FILTER CARD
             ================================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="0,0,20,20"
                Padding="32,20,32,24"
                Margin="24,0,24,0">
            <Border.Effect>
                <DropShadowEffect Color="#6C63FF" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
            </Border.Effect>

            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="← Back"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BackCommand}"
                            Padding="14,8" FontSize="13"
                            VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="Search"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Filter fields in a 2x2 grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 1. Platform -->
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Platform" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding FilterPlatform, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <!-- 2. Purpose -->
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Purpose" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding FilterPurpose, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <!-- 3. Category -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Category" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding FilterCategory, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <!-- 4. Name of the Channel -->
                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Name of the Channel" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding FilterChannel, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ================================================================
             RESULTS LIST
             ================================================================ -->
        <Grid Grid.Row="1" Margin="24,12,24,16">

            <!-- Loading indicator -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="⏳ Loading your links..."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility},
                                    ConverterParameter=Invert}">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilteredLinks.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Results scroll view -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility},
                                      ConverterParameter=Invert}">
                <ItemsControl ItemsSource="{Binding FilteredLinks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:VideoLink}">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: metadata -->
                                    <StackPanel Grid.Column="0">
                                        <!-- Channel name -->
                                        <TextBlock Text="{Binding NameOfChannel}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>

                                        <!-- Tags row -->
                                        <WrapPanel Margin="0,0,0,0">
                                            <!-- Platform tag -->
                                            <Border Style="{StaticResource TagStyle}"
                                                    Background="{DynamicResource AccentLightBrush}">
                                                <TextBlock Foreground="{DynamicResource AccentBrush}"
                                                           FontSize="12" FontWeight="SemiBold">
                                                    <Run Text="📱 "/>
                                                    <Run Text="{Binding Platform}"/>
                                                </TextBlock>
                                            </Border>

                                            <!-- Purpose tag -->
                                            <Border Style="{StaticResource TagStyle}"
                                                    Background="#FEF3C7">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#92400E">
                                                    <Run Text="🎯 "/>
                                                    <Run Text="{Binding Purpose}"/>
                                                </TextBlock>
                                            </Border>

                                            <!-- Category tag -->
                                            <Border Style="{StaticResource TagStyle}"
                                                    Background="#D1FAE5">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#065F46">
                                                    <Run Text="🏷️ "/>
                                                    <Run Text="{Binding Category}"/>
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Right: Open Video button -->
                                    <Button Grid.Column="1"
                                            Content="▶  Open Video"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding DataContext.OpenLinkCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="16,10"
                                            FontSize="13"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>

</UserControl>
